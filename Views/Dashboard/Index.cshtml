@{
    ViewData["Title"] = "Fleet Maintenance";
}

<!-- Display summary statistics -->
<div style="border-radius: 4px;">
    <h3>Dashboard Summary</h3>
    <div style="display:flex; gap: 80px;">
        <div style="display: flex; flex-direction: column; gap: 6px;">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Total Revenue</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">RM @ViewBag.TotalRevenue</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 6px;">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Total Bookings</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.TotalBookings ?? 0)</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 6px;">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Active</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.Active ?? 0)</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 6px;">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Completed</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.Completed ?? 0)</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 6px;">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Cancelled</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.Cancelled ?? 0)</p>
        </div>
    </div>
</div>

<!-- Display revenue bar chart -->
<div style="margin-top:60px;">
    <h3>Monthly Revenue (Last 6 Months)</h3>
    <canvas id="monthlyRevenueChart"></canvas>
</div>

<!-- Revenue breakdown by cars -->
<div style="display:flex; flex-direction: column; gap:20px; margin-top: 60px">
    <h3>Revenue Breakdown by Cars (Last 6 Months)</h3>
    <div style="width: 400px; height: 400px; margin: 0 auto;">
        <canvas id="carRevenueChart"></canvas>
    </div>
</div>

<!-- Revenue comparison YoY, MoM -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap:40px; margin-top:60px;">
        <div style="display:flex; flex-direction: column; gap:20px;">
            <h3>Revenue Comparison Year-over-Year (YoY)</h3>
            <div style="width: 80%; height: 300px;">
                <canvas id="revenueYoYChart"></canvas>
            </div>
        </div>
        <div>
            <h3>Revenue Comparison Month-over-Month (MoM)</h3>
            <div style="width: 80%; height: 300px;">
                <canvas id="revenueMoMChart"></canvas>
            </div>
        </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Get a list of total revenue by month for the last 6 months
        var monthlyRevenue = @Html.Raw(Json.Serialize(ViewBag.MonthlyRevenue));
        const monthlyRevenueLabels = monthlyRevenue.map(m => `${m.month.toString().padStart(2, '0')}-${m.year}`);
        const monthlyRevenueData = monthlyRevenue.map(m => m.revenue);

        new Chart(document.getElementById('monthlyRevenueChart'), {
            type: 'line',
            data: {
                labels: monthlyRevenueLabels,
                datasets: [{
                    label: 'Monthly Revenue (RM)',
                    data: monthlyRevenueData,
                    borderWidth: 2,
                    tension: 0.3,
                    //backgroundColor: 'rgba(54, 162, 235, 1)',
                }]
            }
        });

        // Get revenue breakdown by cars
        var monthlyRevenueByCar = @Html.Raw(Json.Serialize(ViewBag.MonthlyRevenueByCar));
        const carLabels = monthlyRevenueByCar.map(c => `Car ${c.carId}`);
        const carData = monthlyRevenueByCar.map(c => c.revenue);
        const carColors = [
            'rgba(255, 99, 132, 1)',   // red
            'rgba(54, 162, 235, 1)',   // blue
            'rgba(255, 206, 86, 1)',   // yellow
            'rgba(75, 192, 192, 1)',   // teal
            'rgba(153, 102, 255, 1)',  // purple
            'rgba(255, 159, 64, 1)',   // orange
            'rgba(201, 203, 207, 1)',  // gray
            'rgba(255, 0, 255, 1)',    // magenta
            'rgba(0, 255, 0, 1)',      // green
            'rgba(0, 0, 255, 1)',      // deep blue
            'rgba(255, 255, 0, 1)',    // bright yellow
            'rgba(0, 255, 255, 1)',    // cyan
            'rgba(128, 0, 128, 1)',    // dark purple
            'rgba(255, 165, 0, 1)',    // amber
            'rgba(0, 128, 0, 1)'       // dark green
        ];

        new Chart(document.getElementById('carRevenueChart'), {
            type: 'doughnut',
            data: {
                labels: carLabels,
                datasets: [{
                    label: 'Revenue by Car (RM)',
                    data: carData,
                    backgroundColor: carColors,
                    hoverOffset: 4,
                    borderWidth: 1
                }],
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            },
        });

        // Get revenue comparison YoY, MoM
        const revenueYoYLabels = ['Same Month Last Year', 'This Month'];
        var currentMonthRevenue = @ViewBag.CurrentMonthRevenue;
        var revenueYoYData = [@ViewBag.RevenueSameMonthLastYear, currentMonthRevenue];
        const revenueYoYColors = ['rgba(255, 99, 132, 1)', 'rgba(54, 162, 235, 1)'];

        new Chart(document.getElementById('revenueYoYChart'), {
            type: 'bar',
            data: {
                labels: revenueYoYLabels,
                datasets: [{
                    label: 'Revenue YoY (RM)',
                    data: revenueYoYData,
                    backgroundColor: revenueYoYColors,
                }]
            },
            options: {
                scales: {
                    y: {
                        beginAtZero: true
                    }
                },
                indexAxis: 'y' // Display as horizontal bar chart
            }
        });

        const revenueMoMLabels = ['Previous Month', 'This Month'];
        var revenueMoMData = [@ViewBag.PreviousMonthRevenue, @ViewBag.CurrentMonthRevenue];
        const revenueMoMColors = ['rgba(255, 0, 255, 1)', 'rgba(75, 192, 192, 1)'];

        new Chart(document.getElementById('revenueMoMChart'), {
            type: 'bar',
            data: {
                labels: revenueMoMLabels,
                datasets: [{
                    label: 'Revenue MoM (RM)',
                    data: revenueMoMData,
                    backgroundColor: revenueMoMColors,
                }]
            },
            options: {
                scales: {
                    y: {
                        beginAtZero: true
                    }
                },
                indexAxis: 'y' // Display as horizontal bar chart
            }
        });
    </script>
}