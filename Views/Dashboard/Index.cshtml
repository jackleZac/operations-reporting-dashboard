@{
    ViewData["Title"] = "Fleet Maintenance";
}

<style>
    .summary-card {
        display: flex;
        flex-direction: column;
        gap: 8px;
        background-color: #e7e7e7;
        padding: 12px;
        border-radius: 4px;
        width: 200px;
    }

    .chart-empty-state {
        display: none;
        position: absolute;
        inset: 0;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 8px;
        border-radius: 6px;
        pointer-events: none;
        z-index: 1;
    }

    .chart-empty-state .empty-icon {
        font-size: 2em;
        opacity: 0.35;
    }

    .chart-empty-state .empty-label {
        font-size: 0.85em;
        color: #888;
        font-weight: 500;
        letter-spacing: 0.02em;
    }

    .chart-empty-state.visible {
        display: flex;
    }

    /* Period filter tabs */
    .period-tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 16px;
    }

    .period-tab {
        padding: 5px 14px;
        font-size: 0.8em;
        border: 1px solid #ccc;
        border-radius: 20px;
        background: #fff;
        color: #555;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .period-tab:hover {
        border-color: #888;
        color: #222;
    }

    .period-tab.active {
        background: #222;
        color: #fff;
        border-color: #222;
    }
</style>

<!-- Display summary statistics -->
<div style="border-radius: 4px;">
    <h3>Dashboard Summary</h3>
    <div style="display:flex; gap: 40px; flex-wrap: wrap; flex-direction: row; margin-top: 20px;">
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Total Revenue (RM)</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.TotalRevenue</p>
        </div>
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Total Bookings</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.TotalBookings ?? 0)</p>
        </div>
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Active</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.Active ?? 0)</p>
        </div>
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Completed</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.Completed ?? 0)</p>
        </div>
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Cancelled</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@(ViewBag.Cancelled ?? 0)</p>
        </div>
    </div>
</div>

<!-- Display revenue line chart -->
<div style="margin-top:60px;">
    <h3>Monthly Revenue</h3>
    <div class="period-tabs" id="monthlyRevenueTabs">
        <button class="period-tab" data-period="thisMonth" onclick="setMonthlyRevenuePeriod(this)">This Month</button>
        <button class="period-tab" data-period="3m" onclick="setMonthlyRevenuePeriod(this)">Last 3 Months</button>
        <button class="period-tab active" data-period="6m" onclick="setMonthlyRevenuePeriod(this)">Last 6 Months</button>
    </div>
    <div style="position: relative;">
        <canvas id="monthlyRevenueChart"></canvas>
        <div class="chart-empty-state" id="monthlyRevenueEmpty">
            <span class="empty-icon">📊</span>
            <span class="empty-label">No report available</span>
        </div>
    </div>
</div>

<!-- Revenue breakdown by cars -->
<div style="display:flex; flex-direction: column; gap:20px; margin-top: 60px">
    <h3>Revenue Breakdown by Cars</h3>
    <div class="period-tabs" id="carRevenueTabs">
        <button class="period-tab" data-period="thisMonth" onclick="setCarRevenuePeriod(this)">This Month</button>
        <button class="period-tab" data-period="3m" onclick="setCarRevenuePeriod(this)">Last 3 Months</button>
        <button class="period-tab active" data-period="6m" onclick="setCarRevenuePeriod(this)">Last 6 Months</button>
    </div>
    <div style="width: 400px; height: 400px; margin: 0 auto; position: relative;">
        <canvas id="carRevenueChart"></canvas>
        <div class="chart-empty-state" id="carRevenueEmpty">
            <span class="empty-icon">🚗</span>
            <span class="empty-label">No report available</span>
        </div>
    </div>
</div>

<!-- Revenue comparison YoY, MoM -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap:40px; margin-top:60px;">
    <div style="display:flex; flex-direction: column; gap:20px;">
        <h3>Revenue Comparison Year-over-Year (YoY)</h3>
        <div style="width: 80%; height: 300px; position: relative;">
            <canvas id="revenueYoYChart"></canvas>
            <div class="chart-empty-state" id="revenueYoYEmpty">
                <span class="empty-icon">📅</span>
                <span class="empty-label">No report available</span>
            </div>
        </div>
    </div>
    <div>
        <h3>Revenue Comparison Month-over-Month (MoM)</h3>
        <div style="width: 80%; height: 300px; position: relative;">
            <canvas id="revenueMoMChart"></canvas>
            <div class="chart-empty-state" id="revenueMoMEmpty">
                <span class="empty-icon">📅</span>
                <span class="empty-label">No report available</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Helper: show/hide the empty state overlay based on whether data has any non-zero values
        function setEmptyState(data, emptyElementId) {
            const hasData = Array.isArray(data) && data.some(v => v > 0);
            const el = document.getElementById(emptyElementId);
            if (hasData) {
                el.classList.remove('visible');
            } else {
                el.classList.add('visible');
            }
        }

        // -----------------------------------------------------------------------
        // Monthly Revenue data sets (all three periods, pre-serialized from server)
        // -----------------------------------------------------------------------
        const monthlyRevenueDatasets = {
            thisMonth: @Html.Raw(Json.Serialize(ViewBag.MonthlyRevenueThisMonth)),
            '3m':      @Html.Raw(Json.Serialize(ViewBag.MonthlyRevenue3M)),
            '6m':      @Html.Raw(Json.Serialize(ViewBag.MonthlyRevenue6M)),
        };

        function buildMonthlyRevenueChartData(period) {
            const rows = monthlyRevenueDatasets[period];
            return {
                labels: rows.map(m => `${m.month.toString().padStart(2, '0')}-${m.year}`),
                values: rows.map(m => m.revenue),
            };
        }

        // Create the monthly revenue line chart
        const monthlyRevenueChart = new Chart(document.getElementById('monthlyRevenueChart'), {
            type: 'line',
            data: {
                labels: [],
                datasets: [{
                    label: 'Monthly Revenue (RM)',
                    data: [],
                    borderWidth: 2,
                    tension: 0.3,
                }]
            }
        });

        function updateMonthlyRevenueChart(period) {
            const { labels, values } = buildMonthlyRevenueChartData(period);
            monthlyRevenueChart.data.labels = labels;
            monthlyRevenueChart.data.datasets[0].data = values;
            monthlyRevenueChart.update();
            setEmptyState(values, 'monthlyRevenueEmpty');
        }

        function setMonthlyRevenuePeriod(btn) {
            document.querySelectorAll('#monthlyRevenueTabs .period-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            updateMonthlyRevenueChart(btn.dataset.period);
        }

        // Initialize with Last 6 Months
        updateMonthlyRevenueChart('6m');

        // -----------------------------------------------------------------------
        // Revenue Breakdown by Cars — data sets for all three periods
        // -----------------------------------------------------------------------
        const carRevenueDatasets = {
            thisMonth: @Html.Raw(Json.Serialize(ViewBag.RevenueByCarThisMonth)),
            '3m':      @Html.Raw(Json.Serialize(ViewBag.RevenueByCar3M)),
            '6m':      @Html.Raw(Json.Serialize(ViewBag.RevenueByCar6M)),
        };

        const carColors = [
            'rgba(255, 99, 132, 1)',
            'rgba(54, 162, 235, 1)',
            'rgba(255, 206, 86, 1)',
            'rgba(75, 192, 192, 1)',
            'rgba(153, 102, 255, 1)',
            'rgba(255, 159, 64, 1)',
            'rgba(201, 203, 207, 1)',
            'rgba(255, 0, 255, 1)',
            'rgba(0, 255, 0, 1)',
            'rgba(0, 0, 255, 1)',
            'rgba(255, 255, 0, 1)',
            'rgba(0, 255, 255, 1)',
            'rgba(128, 0, 128, 1)',
            'rgba(255, 165, 0, 1)',
            'rgba(0, 128, 0, 1)'
        ];

        function buildCarChartData(period) {
            const rows = carRevenueDatasets[period];
            return {
                labels: rows.map(c => `Car ${c.carId}`),
                values: rows.map(c => c.revenue),
            };
        }

        // Create the car revenue doughnut chart
        const carRevenueChart = new Chart(document.getElementById('carRevenueChart'), {
            type: 'doughnut',
            data: {
                labels: [],
                datasets: [{
                    label: 'Revenue by Car (RM)',
                    data: [],
                    backgroundColor: carColors,
                    hoverOffset: 4,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        function updateCarRevenueChart(period) {
            const { labels, values } = buildCarChartData(period);
            carRevenueChart.data.labels = labels;
            carRevenueChart.data.datasets[0].data = values;
            carRevenueChart.update();
            setEmptyState(values, 'carRevenueEmpty');
        }

        function setCarRevenuePeriod(btn) {
            document.querySelectorAll('#carRevenueTabs .period-tab').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            updateCarRevenueChart(btn.dataset.period);
        }

        // Initialize with Last 6 Months
        updateCarRevenueChart('6m');

        // -----------------------------------------------------------------------
        // Revenue YoY (horizontal bar chart)
        // -----------------------------------------------------------------------
        var currentMonthRevenue = @ViewBag.CurrentMonthRevenue;
        var revenueYoYData = [@ViewBag.RevenueSameMonthLastYear, currentMonthRevenue];

        new Chart(document.getElementById('revenueYoYChart'), {
            type: 'bar',
            data: {
                labels: ['Same Month Last Year', 'This Month'],
                datasets: [{
                    label: 'Revenue YoY (RM)',
                    data: revenueYoYData,
                    backgroundColor: ['rgba(255, 99, 132, 1)', 'rgba(54, 162, 235, 1)'],
                }]
            },
            options: {
                scales: { y: { beginAtZero: true } },
                indexAxis: 'y'
            }
        });

        setEmptyState(revenueYoYData, 'revenueYoYEmpty');

        // -----------------------------------------------------------------------
        // Revenue MoM (horizontal bar chart)
        // -----------------------------------------------------------------------
        var revenueMoMData = [@ViewBag.PreviousMonthRevenue, @ViewBag.CurrentMonthRevenue];

        new Chart(document.getElementById('revenueMoMChart'), {
            type: 'bar',
            data: {
                labels: ['Previous Month', 'This Month'],
                datasets: [{
                    label: 'Revenue MoM (RM)',
                    data: revenueMoMData,
                    backgroundColor: ['rgba(255, 0, 255, 1)', 'rgba(75, 192, 192, 1)'],
                }]
            },
            options: {
                scales: { y: { beginAtZero: true } },
                indexAxis: 'y'
            }
        });

        setEmptyState(revenueMoMData, 'revenueMoMEmpty');
    </script>
}
