@{
    ViewData["Title"] = "Fleet Maintenance";
}

<style>
    .summary-card {
        display: flex;
        flex-direction: column;
        gap: 8px;
        background-color: #e7e7e7;
        padding: 12px;
        border-radius: 4px;
        width: 200px;
    }

    /* Period filter tabs */
    .period-tabs {
        display: flex;
        gap: 4px;
        margin-bottom: 16px;
    }

    .period-tab {
        padding: 5px 14px;
        font-size: 0.8em;
        border: 1px solid #ccc;
        border-radius: 20px;
        background: #fff;
        color: #555;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .period-tab:hover {
        border-color: #888;
        color: #222;
    }

    .period-tab.active {
        background: #222;
        color: #fff;
        border-color: #222;
    }
</style>

<!-- Maintenance Works This Month -->
<section>
    <div>
        <h3>Number of Maintenance Works This Month</h3>
    </div>
    <div style="display: flex; gap: 80px;">
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Opened</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.OpenedCount</p>
        </div>
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">In Progress</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.InProgressCount</p>
        </div>
        <div class="summary-card">
            <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Completed</p>
            <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.CompletedCount</p>
        </div>
    </div>
</section>

<!-- Monthly Maintenance Cost -->
<section style="margin-top: 60px;">
    <div>
        <div>
            <h3>Total Cost of Maintenance</h3>
            <p>Monthly maintenance cost trend.</p>
        </div>
        <div class="period-tabs" id="monthlyMaintenanceCostTabs">
            <button class="period-tab" data-period="3months" onclick="setMonthlyMaintenanceCostPeriod(this)">Last 3 Months</button>
            <button class="period-tab active" data-period="6months" onclick="setMonthlyMaintenanceCostPeriod(this)">Last 6 Months</button>
        </div>
    </div>

    <div>
        <canvas id="monthlyMaintenanceCostChart"></canvas>
    </div>
</section>

<!-- Expense Per Service Type -->
<section style="margin-top: 60px;">
    <div>
        <div>
            <h3>Service Type (This Month)</h3>
            <p>Total Expense per Service Type</p>
        </div>
    </div>

    <div>
        <canvas id="expensePerServiceTypeChart"></canvas>
    </div>
</section>

<section style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 60px;">
    <!-- High Maintenance Cars -->
    <div style="width: 80%;">
        <div style="margin-bottom: 4px">
            <div style="display: flex; flex-direction: column; gap: 4px;">
                <h3>High Maintenance Cars</h3>
                <div class="period-tabs" id="highMaintenanceCarsTabs">
                    <button class="period-tab" data-period="3months" onclick="setMaintenanceCarsPeriod(this)">Last 3 Months</button>
                    <button class="period-tab" data-period="6months" onclick="setMaintenanceCarsPeriod(this)">Last 6 Months</button>
                    <button class="period-tab active" data-period="thisyear" onclick="setMaintenanceCarsPeriod(this)">This Year</button>
                </div>
            </div>
            <p>Cars whose maintenance costs exceed 20% of total rental revenue.</p>
        </div>

        <div id="highMaintenanceCarsContainer">
            <! -- Initial rendering of high-maintenance cars for the default period (this year) -->
            @if (ViewBag.HighMaintenanceCarsThisYear != null && ViewBag.HighMaintenanceCarsThisYear.Count > 0)
            {
                foreach (var car in ViewBag.HighMaintenanceCarsThisYear)
                {
                    <div style="margin-bottom: 4px; padding: 12px 16px; border: 1px solid #bababa; border-width: 0 0 1px 0;">
                        <h3 style="margin: 4px 0 0 0;">@car.carName</h3>
                        <div style="margin: 2px 0 0 0; display: flex; flex-direction: row; justify-content: space-between;">
                            <div>
                                <p style="font-size: 0.9em; font-weight: 400; color: #404040;">Total maintenance cost</p>
                                <p style="font-size: 1.4 em; font-weight: 600;">RM @car.totalMaintenanceCost.ToString("F2")</p>
                            </div>
                            <div style="text-align: right;">
                                <p style="font-size: 0.9em; font-weight: 400; color: #404040;">@car.maintenanceRatio.ToString("F2")%</p>
                                <p style="font-size: 1.4 em; font-weight: 600;">Ratio</p>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p>No high-maintenance cars found.</p>
            }
        </div>
    </div>

    <!-- Number of Services Per Type -->
    <div style="width: 80%">
        <div>
            <h3>Service Type</h3>
            <p>Number of Services (This Year)</p>
        </div>
        <div style="height: 520px;">
            <canvas id="serviceCountChart"></canvas>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Data from Controller
        const expensePerServiceType = @Html.Raw(Json.Serialize(ViewBag.ExpensePerServiceType));
        const serviceCountPerType = @Html.Raw(Json.Serialize(ViewBag.ServiceCountPerType));
        const totalMaintenanceCostLast6Months = @Html.Raw(Json.Serialize(ViewBag.TotalMaintenanceCostLast6Months));
        const totalMaintenanceCostLast3Months = @Html.Raw(Json.Serialize(ViewBag.TotalMaintenanceCostLast3Months));
        const totalMaintenanceCostThisYear = @Html.Raw(Json.Serialize(ViewBag.TotalMaintenanceCostThisYear));

        // List of high-maintenance cars
        function setMaintenanceCarsPeriod(btn) {
            document.querySelectorAll('#highMaintenanceCarsTabs .period-tab')
                .forEach(t => t.classList.remove('active'));
            btn.classList.add('active');

            const period = btn.dataset.period;
            let carsData;

            switch (period) {
                case '3months':
                    carsData = @Html.Raw(Json.Serialize(ViewBag.HighMaintenanceCarsLast3Months));
                    break;
                case '6months':
                    carsData = @Html.Raw(Json.Serialize(ViewBag.HighMaintenanceCarsLast6Months));
                    break;
                case 'thisyear':
                    carsData = @Html.Raw(Json.Serialize(ViewBag.HighMaintenanceCarsThisYear));
                    break;
                default:
                    carsData = [];
            }

            const container = document.querySelector('#highMaintenanceCarsContainer');
            container.innerHTML = '';

            if (carsData.length > 0) {
                carsData.forEach(car => {
                    const carCard = document.createElement('div');
                    carCard.style.marginBottom = '4px';
                    carCard.style.padding = '12px 16px';
                    carCard.style.border = '1px solid #bababa';
                    carCard.style.borderWidth = '0 0 1px 0';

                    carCard.innerHTML = `
                        <h3 style="margin: 4px 0 0 0;">${car.carName}</h3>
                        <div style="margin: 2px 0 0 0; display: flex; flex-direction: row; justify-content: space-between;">
                            <div>
                                <p style="font-size: 0.9em; font-weight: 400; color: #404040;">Total maintenance cost</p>
                                <p style="font-size: 1.4 em; font-weight: 600;">RM ${car.totalMaintenanceCost.toFixed(2)}</p>
                            </div>
                            <div style="text-align: right;">
                                <p style="font-size: 0.9em; font-weight: 400; color: #404040;">Ratio</p>
                                <p style="font-size: 1.4 em; font-weight: 600;">${car.maintenanceRatio}%</p>
                            </div>
                        </div>
                    `;

                    container.appendChild(carCard);
                });
            } else {
                container.innerHTML = '<p>No high-maintenance cars found.</p>';
            }
        };

        // Expense Per Service Type
        const expenseLabels = expensePerServiceType.map(x => x.serviceType);
        const expenseData = expensePerServiceType.map(x => x.totalExpense);

        new Chart(document.getElementById('expensePerServiceTypeChart'), {
            type: 'doughnut',
            data: {
                labels: expenseLabels,
                datasets: [{
                    label: 'Total Expense (RM)',
                    data: expenseData,
                    backgroundColor: [
                        'rgba(255, 99, 132, 1)',   // red
                        'rgba(54, 162, 235, 1)',   // blue
                        'rgba(255, 206, 86, 1)',   // yellow
                        'rgba(75, 192, 192, 1)',   // teal
                        'rgba(153, 102, 255, 1)',  // purple
                        'rgba(255, 159, 64, 1)',   // orange
                        'rgba(201, 203, 207, 1)',  // gray
                        'rgba(255, 0, 255, 1)',    // magenta
                        'rgba(0, 255, 0, 1)',      // green
                        'rgba(0, 0, 255, 1)',      // deep blue
                        'rgba(255, 255, 0, 1)',    // bright yellow
                        'rgba(0, 255, 255, 1)',    // cyan
                        'rgba(128, 0, 128, 1)',    // dark purple
                        'rgba(255, 165, 0, 1)',    // amber
                        'rgba(0, 128, 0, 1)'       // dark green
                    ],
                    hoverOffset: 4,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // Number of Services Per Type
        const serviceCountLabels = serviceCountPerType.map(x => x.serviceType);
        const serviceCountData = serviceCountPerType.map(x => x.count);
        
        // Create chart for service count per type
        new Chart(document.getElementById('serviceCountChart'), {
            type: 'bar',
            data: {
                labels: serviceCountLabels,
                datasets: [{
                    label: 'Number of Services',
                    data: serviceCountData,
                    backgroundColor: '#F54927',
                    borderWidth: 1,
                    categoryPercentage: 0.7,
                    barPercentage: 0.8,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });

        // Monthly Maintenance Cost Trend
        // by default, show last 6 months
        const monthlyCostData = totalMaintenanceCostLast6Months.map(x => x.totalCost);
        const monthlyCostLabels = totalMaintenanceCostLast6Months.map(x =>
            `${x.month.toString().padStart(2, '0')}-${x.year}`
        );
        new Chart(document.getElementById('monthlyMaintenanceCostChart'), {
            type: 'line',
            data: {
                labels: monthlyCostLabels,
                datasets: [{
                    label: 'Maintenance Cost (RM)',
                    data: monthlyCostData,
                    borderColor: '#001B7A',
                    backgroundColor: 'rgba(0, 27, 122, 0.1)',
                    borderWidth: 3,
                    tension: 0.3,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Cost'
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Month'
                        }
                    }
                }
            }
        });

        function buildMonthlyMaintenanceCostChart(data) {
            const monthlyCostLabels = data.map(x =>
                `${x.month.toString().padStart(2, '0')}-${x.year}`
            );

            const monthlyCostData = data.map(x => x.totalCost);

            const chart = Chart.getChart('monthlyMaintenanceCostChart');
            chart.data.labels = monthlyCostLabels;
            chart.data.datasets[0].data = monthlyCostData;
            chart.update();
        }

        function setMonthlyMaintenanceCostPeriod(btn) {
            document.querySelectorAll('#monthlyMaintenanceCostTabs .period-tab')
                .forEach(t => t.classList.remove('active'));
            btn.classList.add('active');

            const data = btn.dataset.period === '3months'
                ? totalMaintenanceCostLast3Months
                : totalMaintenanceCostLast6Months;

            buildMonthlyMaintenanceCostChart(data);
        }

    </script>
}