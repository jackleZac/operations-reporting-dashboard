@{
    ViewData["Title"] = "Fleet Maintenance";
}

<div>
    <!-- Maintenance Works This Month -->
    <section>
        <div>
            <h3>Number of Maintenance Works This Month</h3>
        </div>
        <div style="display: flex; gap: 80px;">
            <div style="display: flex; flex-direction: column; gap: 6px;">
                <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Opened</p>
                <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.OpenedCount</p>
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
                <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">In Progress</p>
                <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.InProgressCount</p>
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
                <p style="margin: 0; padding: 0; font-size: 0.8em; color: #555;">Completed</p>
                <p style="margin: 0; padding: 0; font-size: 1.2em; font-weight: 600;">@ViewBag.CompletedCount</p>
            </div>
        </div>
    </section>

    <!-- Monthly Maintenance Cost -->
    <section style="margin-top: 60px;">
        <div>
            <div>
                <h3>Total Cost of Maintenance</h3>
                <p>Monthly maintenance cost trend.</p>
            </div>
        </div>

        <div>
            <canvas id="monthlyMaintenanceCostChart"></canvas>
        </div>
    </section>

    <!-- Expense Per Service Type -->
    <section style="margin-top: 60px;">
        <div>
            <div>
                <h3>Service Type</h3>
                <p>Total Expense per Service Type</p>
            </div>
        </div>

        <div>
            <canvas id="expensePerServiceTypeChart"></canvas>
        </div>
    </section>

    <section style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 60px;">
        <!-- High Maintenance Cars -->
        <div style="width: 80%;">
            <div style="margin-bottom: 4px">
                <div style="display: flex; flex-direction: row; justify-content: space-between;">
                    <h3>High Maintenance Cars</h3>
                    <button style="height: fit-content; margin: auto 0;">This Year</button>
                </div>
                <p>Cars whose maintenance costs exceed 20% of total rental revenue.</p>
            </div>

            <div>
                @if (ViewBag.HighMaintenanceCars != null && ViewBag.HighMaintenanceCars.Count > 0)
                {
                    foreach (var car in ViewBag.HighMaintenanceCars)
                    {
                        <div style="margin-bottom: 4px; padding: 12px 16px; border: 1px solid #bababa; border-radius: 6px;">
                            <h3>@car.carName</h3>
                            <div style="display: flex; flex-direction: row; justify-content: space-between;">
                                <div>
                                    <p style="font-size: 0.9em; font-weight: 400; color: #404040;">Total maintenance cost</p>
                                    <p style="font-size: 1.4 em; font-weight: 600;">RM @car.totalMaintenanceCost.ToString("N2")</p>
                                </div>
                                <div style="text-align: right;">
                                    <p style="font-size: 0.9em; font-weight: 400; color: #404040;">@car.maintenanceRatio%</p>
                                    <p style="font-size: 1.4 em; font-weight: 600;">Ratio</p>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p>No high-maintenance cars found.</p>
                }
            </div>
        </div>
        <!-- Number of Services Per Type -->
        <div>
            <div>
                <div>
                    <h3>Service Type</h3>
                    <p>Number of Services</p>
                </div>
            </div>
            <div style="height: 520px;">
                <canvas id="serviceCountChart"></canvas>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Data from Controller
        const expensePerServiceType = @Html.Raw(Json.Serialize(ViewBag.ExpensePerServiceType));
        const serviceCountPerType = @Html.Raw(Json.Serialize(ViewBag.ServiceCountPerType));
        const monthlyMaintenanceCost = @Html.Raw(Json.Serialize(ViewBag.MonthlyMaintenanceCost));

        // Expense Per Service Type
        const expenseLabels = expensePerServiceType.map(x => x.serviceType);
        const expenseData = expensePerServiceType.map(x => x.totalExpense);

        new Chart(document.getElementById('expensePerServiceTypeChart'), {
            type: 'doughnut',
            data: {
                labels: expenseLabels,
                datasets: [{
                    label: 'Total Expense (RM)',
                    data: expenseData,
                    backgroundColor: [
                        'rgba(255, 99, 132, 1)',   // red
                        'rgba(54, 162, 235, 1)',   // blue
                        'rgba(255, 206, 86, 1)',   // yellow
                        'rgba(75, 192, 192, 1)',   // teal
                        'rgba(153, 102, 255, 1)',  // purple
                        'rgba(255, 159, 64, 1)',   // orange
                        'rgba(201, 203, 207, 1)',  // gray
                        'rgba(255, 0, 255, 1)',    // magenta
                        'rgba(0, 255, 0, 1)',      // green
                        'rgba(0, 0, 255, 1)',      // deep blue
                        'rgba(255, 255, 0, 1)',    // bright yellow
                        'rgba(0, 255, 255, 1)',    // cyan
                        'rgba(128, 0, 128, 1)',    // dark purple
                        'rgba(255, 165, 0, 1)',    // amber
                        'rgba(0, 128, 0, 1)'       // dark green
                    ],
                    hoverOffset: 4,
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // Number of Services Per Type
        const serviceCountLabels = serviceCountPerType.map(x => x.serviceType);
        const serviceCountData = serviceCountPerType.map(x => x.count);

        new Chart(document.getElementById('serviceCountChart'), {
            type: 'bar',
            data: {
                labels: serviceCountLabels,
                datasets: [{
                    label: 'Number of Services',
                    data: serviceCountData,
                    backgroundColor: '#F54927',
                    borderWidth: 1,
                    categoryPercentage: 0.7,
                    barPercentage: 0.8,
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            precision: 0
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });

        // Monthly Maintenance Cost
        const monthlyCostLabels = monthlyMaintenanceCost.map(x =>
            `${x.month.toString().padStart(2, '0')}-${x.year}`
        );

        const monthlyCostData = monthlyMaintenanceCost.map(x => x.totalCost);

        new Chart(document.getElementById('monthlyMaintenanceCostChart'), {
            type: 'line',
            data: {
                labels: monthlyCostLabels,
                datasets: [{
                    label: 'Maintenance Cost (RM)',
                    data: monthlyCostData,
                    borderColor: '#001B7A',
                    backgroundColor: 'rgba(0, 27, 122, 0.1)',
                    borderWidth: 3,
                    tension: 0.3,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Cost'
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Month'
                        }
                    }
                }
            }
        });
    </script>
}