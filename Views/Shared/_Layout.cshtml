<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Operations Dashboard</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f6f8;
        }

        .app-layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background-color: #043D74;
            color: white;
            padding: 24px 16px;
            flex-shrink: 0;
        }

        .sidebar h2 {
            margin-top: 0;
            margin-bottom: 32px;
            font-size: 1.3rem;
        }

        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .sidebar a:hover {
            background-color: rgba(255, 255, 255, 0.25);
        }

        .sidebar a.active-link {
            background-color: rgba(255, 255, 255, 0.15);
        }

        .main-content {
            flex: 1;
            padding: 32px;
        }

        @@media (max-width: 768px) {
            .app-layout {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
            }

            .main-content {
                padding: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="app-layout">
        @{
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        }
        <aside class="sidebar">
            <h2>Fleet Operations</h2>

            <a asp-controller="Dashboard" asp-action="Index" class="@(currentController == "Dashboard" ? "active-link" : "")">Dashboard</a>
            <a asp-controller="FleetMaintenance" asp-action="Index" class="@(currentController == "FleetMaintenance" ? "active-link" : "")">Fleet Maintenance</a>
        </aside>

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
